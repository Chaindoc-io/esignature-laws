---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign now = site.time | date_to_xmlschema -%}
{%- assign children = "/sitemap-static.xml,/sitemap-docs.xml,/sitemap-handbook.xml" | split: "," -%}
{%- for child in children %}
  <sitemap>
    <loc>{{ child | absolute_url }}</loc>
    <lastmod>{{ now }}</lastmod>
  </sitemap>
{%- endfor %}
</sitemapindex>

